// Custom styles.
body {
  background: url(/images/background.jpg) no-repeat;
  /* 背景图垂直、水平均居中 */
  background-position: center center;
  /* 当内容高度大于图片高度时，背景图像的位置相对于viewport固定 */
  background-attachment: fixed;
  /* 让背景图基于容器大小伸缩 */
  background-size: cover;
  /* 设置背景颜色，背景图加载过程中会显示背景色 */
  background-color: rgba(0, 0, 0, 0.5);
}
#comments {
  margin-top: 12px;
  position: relative;
  a {
    border: none;
  }
}

img.emojione {
  display: inline-block;
}

+mobile() {
  .post-copyright {
    font-size: 14px;
  }
}

.headband { display: none; }

.no-doodle-support {
  background: $gainsboro;

  css-doodle {
    display: none;
  }

  .back-to-top, .sidebar, {
    background: $gainsboro;
  }
}

.doodle-support {
  .post-block, .header-inner, .sidebar-inner, .comments {
    opacity: .9 !important;
  }

  .header {
    z-index: 1;
  }

  .footer a {
    color: white;
    opacity: .9;
  }

  .back-to-top {
    color: rgba(white, .8);
  }
}
#sidebar, .header-inner, .comments {
    opacity: .9 !important;
}
.post-block{
    opacity: .9 !important;
	//background-color: rgba(207, 232, 204, 1);
}
.post-body p a{
  color: #0593d3; //原始链接颜色
  border-bottom: none;
  border-bottom: 1px solid #0593d3; //底部分割线颜色
  &:hover {
    color: #fc6423; //鼠标经过颜色
    border-bottom: none;
    border-bottom: 1px solid #fc6423; //底部分割线颜色
  }
}

.highlight-wrap .copy-btn {
   transition: opacity .3s ease-in-out;
   opacity: 0;
   padding: 2px 6px;
   position: absolute;
   right: 4px;
   top: 0px;
}